for b in *; do
grep . -q  $b || continue;
echo '<script>function f() { window.location.href = window.location.href; }; setTimeout(f, 50);</script><body style="background-color: grey"><div style="position: absolute;top:0px;left:0px;width: 500px; height: 500px; background-color: red;"></div></body>'    > ../graph_$b.html; for ((i=0;  i<50;      ++i)); do cat           "$b"            | t '[i.split[1].to_f - i.split[2].to_f]' | ruby -e 'lines = STDIN.read.split("\n")[-(n = ARGV[0].to_i)..]; lines = lines.map do |i| i.to_f; end; decrease = 100 - lines.sum / lines.size * 100.0; puts("<div style='"'"'opacity: 0.5; background-color: rgb(#{((1..3).map do |i| (1..255).to_a.sample; end).join(", ")}); width: 5px; position: absolute; left: #{n*5}px; top: #{500-decrease*5}px; height: #{decrease * 5}px'"'"'><div style=top:#{rand * 100}px;position:absolute;><i>#{n + 1} days</i></div></div>"); STDERR.puts  "last #{n + 1}" +  [" ", decrease/100.0, " "].join +             ARGV.join(" ")' $i               $b ; done >> /home/a/graph_$b.html
done