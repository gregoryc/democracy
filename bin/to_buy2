async function() {
//return [];
var list = [];
var body = document.querySelectorAll("tbody")
for (var b of body) {
	b =[... b.childNodes  ];
	
for(var i=0; i < b.length;++i) {
	var text = b.at(i).innerText || "";
	var split = text.split("\t");
	var price = "$" + split?.at(1);
	var up = split?.at(2);
	if(text.match(/./i)) { list.push([b.at(i).querySelector("a").innerText,price,up]); } }
}

//alert(list);

return list;
}

