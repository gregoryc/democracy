#!/usr/bin/ruby

system "
cd
mkdir -p Images
cd Images
caja .
"
require "cgi"
require "puppeteer-ruby"
require "colored"

Warning[:deprecated]   = false

Puppeteer.launch headless: false do |i|
ARGV.each do |arg|
val = true
i.pages.first.request_interception=val
i.pages.first.on 'request' do |i|
type = i.resource_type
case type
when /stylesheet|image/
i.abort

else
i.continue
end
end

i.pages.first.goto "https://duckduckgo.com/?q=#{CGI.escape(arg)}&t=h_&iax=images&ia=images&iaf=license%3APublic"

i.pages.first.evaluate(' () =>  {

qs = {}; function get_link() {
qs[[...document.getElementsByClassName("c-detail__btn c-detail__btn--bottom btn js-image-detail-link")].at(1).href] = true; }
i = 0;
function c_tiles() {
document.querySelectorAll(".tile")[i].click();
++i;
}
t = setInterval(c_tiles,12); t2 = setInterval(get_link, 0); } ');

thread = Thread.new do |_|
	warn arg.green
	l = []
	time = Time.now
	while l.length <= 30 && time <= time + 3.5
	l = (i.pages.first.evaluate(" () => { return qs; } ").map do |a, b|
		a
	end).to_a
	sleep 0.001
	end

	puts l
	Dir.chdir Dir.home
	Dir.chdir "Images"
	File.open(arg, "w") do |i|
		i.print l.join("\n")
	end
end
thread.join
#$main_thread.join
end

end

__END__

