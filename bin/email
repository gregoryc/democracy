#!/usr/bin/env ruby
#BG env variable controls whether or not it's background
GREGORYS_USERNAME = "a"
if File.basename(Dir.home) == GREGORYS_USERNAME
#if Dir.basename   (Dir.home) == "a"
	PERSON = "Gregory"
	EMAIL = "gregorycohen2@gmail.com"; else abort "Needs configuring in #{__FILE__} on line #{__LINE__}"
end

if `which himalaya`.empty?
	abort "No himalaya
	Install from here
	https://github.com/soywod/himalaya"
end


def main

done = false


while (`ping -c 1 example.com 2>&1`.match("not known"))
	system "nmcli networking on"
	if !done
		system "notify-send 'Waiting for connectivity to email'"
	end
	done = true
end

if done
	system "notify-send 'Connectivity established'"
end


			

args = case ARGV.length
       when 0
         ['From ' + PERSON] + ARGV + ["#{EMAIL}"]
       when 1
         #	subject = "From Gregory"
         ["From #{PERSON}"] + ARGV
       else
         ARGV
       end

subject = args[0]

from = PERSON + " <" + EMAIL + ">"
begin
content = $stdin.read
rescue Object
	print "  "
	exit 1
end
	require "tempfile"
#STRING=

args = args.reverse
args.pop
args = args.reverse


while true
args.each do |arg|
text=<<~EOF
      To: <#{arg}>
      From: #{from}
      Subject: #{subject}

      #{content.strip}
    EOF
#    puts text
	Tempfile.open do |file|
a = IO.popen("himalaya send 2>&1  | grep -viE '(^\s*$)|cannot|could not|folder|missing|caused by'   1> #{file.path}", 'w') do |h|
	
h.puts text
end
	if File.read(file.path).strip == ""
		exit 0
	else
		Kernel.warn "Resending email to #{arg.shellescape}"
		require "shellwords"
		system "notify-send 'Resending email to #{arg.shellescape}'"
    end
    end
end
end

end



if !STDIN.tty? &&ENV["BG"]=="true"
	fork do
		main
	end
	exit 0
end

main