class Button < Gtk::Button
  def initialize(tv)
    @tv = tv
    $tv = tv
    super(label: '_Regenerate', use_underline: true)

    #    signal_connect 'button-press-event' do |i|

    add_event_listener 'clicked' do
      @tv.buffer.text = gettext
    end

    #    add_event_listener 'clicked' do |_i|
    #	    @tv.buffer.text = gettext
    #    end
  end
end

