def watch
  Thread.new do |_i|
  loop do
  if $args.nil?
  	sleep 0.5
  	next; end
  new = ""
  $args.each do |arg|; %w[TO CN V].each { |suf| new += arg + "." + suf + ","; }; # end
                    puts new
    # + suf + ","; end
  end

  args = new
  puts args

  a = 'https://query1.finance.yahoo.com/v7/finance/quote?lang=en-CA&region=CA&corsDomain=ca.finance.yahoo.com&fields=symbol,marketState,regularMarketPrice,regularMarketChange,regularMarketChangePercent,preMarketPrice,preMarketChange,preMarketChangePercent,postMarketPrice,postMarketChange,postMarketChangePercent&symbols=' + args
  text = ""
  a = IO.popen("timeout 1s curl -s #{a.shellescape} 2>/dev/null") do |i|
  	text = i.read.strip
  end
  if text == ""
  	next
  end

  # a =  JSON.parse(a)

  # a["quote


  a = JSON.parse(a)

  a = a["quoteResponse"]

  result = a["result"]
  #	system "tput reset"
  #	puts Time.now
  msgs = ""
  result.each do |i|
  	# i = i.sortz
  	if i["market"] != "us_market"
   #	print i["market"], i["regularMarketPrice"]
  	market = i["market"]
  	p = i["regularMarketPrice"]
   #	arg = args[0]
   #	a
  	msgs += "#{i['symbol']} #{p} #{market}" + "\n"
   #	if !$tv

  	if $tv
  		 # $tv.buffer.text  = $tv.buffer.text.split("Prices") + msg
  	end
  	end
  end
  if $tv
  	buffer = $tv.buffer
  	$tv.buffer.text = $tv.buffer.text.split(/Prices below.+\n/m)[0] + "Prices below #{get_time}\n\n\n\n\n#{msgs}" #+ msg

  	mark = buffer.create_mark "", buffer.end_iter, false
  	$tv.scroll_to_mark  mark, 0.0, false, 0.0, 0.0

  end

  begin
  end
  sleep 0.5
  end
    # end
  end
end


