class EntryBox < Gtk::Box
  def initialize(button)
    super(:horizontal)
    @button = button

    pack_start(Gtk::Label.new('Enter free money $ '))
    # @button
    #	$entry.width = 1000
    #	pack_start $entry, true, true
    def $entry.button
      button
    end
    $entry.add_event_listener('activate') do |_i|
      #		button.signal_emit_by_name "cl

      button.signal_emit 'clicked'
    end
    #		@button.emit"clicked"
    #	end
    pack_start($entry, true, true)
  end
end

#	def initialize
class Box < Gtk::Box
  #	def initialize

  def initialize(a)
    super(:vertical)
    tv = TextView.new a
    #    button = Button.new(tv)
    pack_start(Scrolled.new(a, tv))
    #   Button.new(tv)
    #    buButton.new(tv)
    button = Button.new(tv)
    pack_start EntryBox.new(button)
    # pack_start$entry


    pack_start BB.new(button), true, true, 5
  end
end

class BB < Gtk::Box
  def initialize(a)
  super(:horizontal)
  pack_start(a, true, false)
  pack_start(B.new("Quit"), true, false)
