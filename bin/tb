class Scrolled < Gtk::ScrolledWindow
  def initialize(tv, big)
    super()
    add tv
    #    self.title = "There is no risk"
    if big
      set_size_request(*[330, 200])
      return
    end

    set_size_request(*[400,200])
  end
end

def get_time
  time = Time.now
  sec = time.sec.to_s
  min = time.min.to_s
  hour  = time.hour

  pm = hour >= 12
  text = if pm
           'pm'
         else
           'am'
         end
  text = text.upcase

  first = '\1'
  hour %= 13
  hour += 1
  " #{hour}:0#{min}:0#{sec}#{text}".gsub(/[0-9]([0-9]{2})/, first)
end
#  ,first)
# end

def set_time
  $window.title = get_time
end

