require 'gtk3'
class TextView < Gtk::TextView
  def initialize(a)
    super()
    buffer.text = a.to_s

    self.cursor_visible = false
    self.editable = false
    self.left_margin = 20

    self.right_margin = 20

    self.top_margin = 20

    self.bottom_margin = 20
  end
end

module Gtk
  class Widget
    alias :add_event_listener signal_connect
  end
end

