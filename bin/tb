def fade(obj, start, stop)
  Thread.new do |i|
    i = start.to_f
    loop do
      obj.set_opacity i += ((stop - start) / 100.0)
      sleep 0.0005
      if (stop - start).positive?
        break if i >= stop; elsif i <= stop
                              break
      end
    end
    yield if block_given?
  end
end


