class Scrolled < Gtk::ScrolledWindow
  def initialize(_a, tv)
    super()
    add tv
    #    self.title = "There is no risk"

    set_size_request(*[550, 830].reverse)
  end
end

def get_time
  time = Time.now
  sec = time.sec.to_s
  min = time.min.to_s
  hour  = time.hour

  pm = hour > 12
  text = if pm
  	 "pm"
  else
  	 "am"
         end
  text = text.upcase


  first = '\1'
  " #{hour % 12}:0#{min}:0#{sec}#{text}".gsub(/[0-9]([0-9]{2})/, first); 
end
#  ,first)
# end

def set_time
	 $window.title = get_time
end

