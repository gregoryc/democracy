class TextView < Gtk::TextView
  def initialize(a)
    super()
    set a.to_s

    self.cursor_visible = false
    self.editable = false
    self.left_margin = 20

    self.right_margin = 20

    self.top_margin = 20

    self.bottom_margin = 20
  end

#  def set
def set(arg)
  	self.buffer&.text = ""
self.buffer.insert_markup((self.buffer.start_iter),arg,arg.length); 
end

end
