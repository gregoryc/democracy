def watch
  Thread.new do |_i|
    def puts(*a); end
    loop do
      if $args.nil?
        sleep 0.5
        next; end
      new = ''
      $args.each do |arg|
        %w[TO CN V].each { |suf| new += "#{arg}.#{suf},"; }; # end
        puts new
        # + suf + ","; end
      end

      args = new
      puts args

      a = "https://query1.finance.yahoo.com/v7/finance/quote?lang=en-CA&region=CA&corsDomain=ca.finance.yahoo.com&fields=symbol,marketState,regularMarketPrice,regularMarketChange,regularMarketChangePercent,preMarketPrice,preMarketChange,preMarketChangePercent,postMarketPrice,postMarketChange,postMarketChangePercent&symbols=#{args}"
      text = ''
      a = IO.popen("timeout 1s curl -s #{a.shellescape} 2>/dev/null") do |i|
        text = i.read.strip
      end
      next if text == ''

      # a =  JSON.parse(a)

      # a["quote

      a = JSON.parse(a)

      a = a['quoteResponse']

      result = a['result']
      #	puts Time.now
      msgs = ''
      x = 0
      symbols = result.map do |i|
        i['symbol']
      end
      $symbols = symbols

      result.each do |i|
        # i = i.
        next unless i['market'] != 'us_market'

        #	print i["market"], i["regularMarketPrice"]
        market = i['market']
        p = i['regularMarketPrice']
        #  	symbols.ps             symbol = i['symbol']

        symbol = i['symbol']
        #  	symbols.push
        #	arg = args[0]
        #	a
        msgs += "#{symbol} #{p} #{market} | "
        msgs += "\n" if (x % 5).zero?
        #  		msgs += "\n"
        # 	end

        #  	x += 1
        #	if !$tv
        x += 1
        if $tv
        end
      end; if $tv2; $tv2.set "<i>Volatile stock prices <b>#{get_time}</b></i>\n\n\n#{msgs}" ; end
     # $tv2&.text =          (m = "Prices below #{get_time}\n#{msgs}")


