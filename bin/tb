class B < Gtk::Button
  def initialize(a)
    super(label: a, use_underline: true)
    add_event_listener 'clicked' do |_i|
      fade($window, 1, 0) do |_i|
        Gtk.main_quit
        exit 0
      end
    end
  end
end

