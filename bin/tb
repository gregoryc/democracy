require 'puppeteer-ruby'
require 'gtk3'
class TextView < Gtk::TextView
  def initialize(a)
    super()
    buffer.text = a.to_s

    self.cursor_visible = false
    self.editable = false
    self.left_margin = 20
    self.right_margin = 20
  end
end

module Gtk
  class Widget
    alias :add_event_listener signal_connect
  end
end

# class Button < G
class Button < Gtk::Button
  def initialize(tv)
    @tv = tv
    super(label = 'Regenerate')

    #    signal_connect 'button-press-event' do |i|

    add_event_listener 'button-press-event' do |_i|
	@tv.buffer.text = gettext
	end
  end
end

# class Box < Gtk::VBox
class EntryBox < Gtk::Box; def initialize
	super(:horizontal)


	pack_start               (Gtk::Label.new "Enter free money $" )
#	$entry.width = 1000
#	pack_start $entry, true, true

	pack_start($entry, true, true)
end
end

#	def initialize
class Box < Gtk::Box
  #	def initialize

  def initialize(a);    super(:vertical);                 tv = TextView.new a; 
    pack_start(Scrolled.new(a, tv))
    pack_start EntryBox.new
#pack_start$entry
    
    pack_start Button.new(tv)
  end
end

class Scrolled < Gtk::ScrolledWindow
  def initialize(a, tv)
    super()
    add tv
#    self.title = "There is no risk"
    set_size_request 600, 600
  end
end

class OutputWindow < Gtk::Window
  def initialize(window_text)
    super()
    add Box.new window_text
    self.title = "There is no risk"
    show_all
    Gtk.main
  end
end

