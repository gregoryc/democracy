import std.string;

string get_sentence_to_speak(string sentence) {
	return (
		sentence.
		replace("Sasuke", "Sauskay").
		replace("Popeye", "Pop eye").
		replace("Alan Turing", "Alan Turring").
		replace("Jasna", "Yasna").
		replace("Osama Bin Laden", "Osama Bin Laaden").
		replace("Vietnamese", "Vietnam-ese").
		replace("Donald Knuth", "Donald kuhNooth").
		replace("philosopher", "phil-osopher").
		replace("GLADoS", "Gladohs").
		replace("cocaine", "cohcAin").
		replace("Ulquiorra", "Yoolkee-orra").
		replace("Mr. T's", "Mr. Tees").
		replace("demonlike", "deemonlike").
		replace("cantaloupe", "cantalope").
		replace("content", "cun-tent").
		replace("John McCain", "John Mik-ain").
		replace("advertisement", "advertizement").
		replace("Uranus", "Your anus").
		replace("Titanic", "Tietanic").
		replace("complex", "com-plex").
		replace("retard", "ree-tard").
		replace("Eminem", "MNM").
		replace("Tamalei", "Tamalay").
		replace("diamond", "die-mond")
	);
}
